<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!--
      服务端启动前保留空节点占位。
      点击“启动服务”后，如果值为空或无效，程序会自动生成并写回当前运行环境对应的标准 .NET 配置文件。
    -->
    <add key="TcpIp" value="" />
    <add key="TcpPort" value="" />
    <add key="UdpIp" value="" />
    <add key="UdpPort" value="" />
  </appSettings>
</configuration>
