<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SocketTest.Server.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:codewf="https://codewf.com"
        mc:Ignorable="d" d:DesignWidth="650" d:DesignHeight="650" Width="650" Height="650"
        x:Class="SocketTest.Server.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.ico"
        Title="Socket服务端(承载TCP服务和UDP组播)">
    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBox.form">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Height" Value="23" />
        </Style>
        <Style Selector="HeaderedContentControl.form">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="15,2" />
            <Setter Property="Margin" Value="10,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Styles>
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>
    <TabControl>
        <TabItem Header="服务配置">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <HeaderedContentControl Grid.Row="0" Header="Tcp服务配置">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,5,0" Text="IP：" />
                        <TextBox Width="150" Text="{Binding TcpIp, Mode=TwoWay}" />

                        <TextBlock Margin="10,0,5,0" Text="端口：" />
                        <TextBox Width="60" Text="{Binding TcpPort, Mode=TwoWay}" />
                        <TextBlock Margin="10,0,5,0" Text="模拟总数：" />
                        <TextBox Width="80"
                                 Text="{Binding MockCount, Mode=TwoWay}" />
                        <TextBlock Margin="10,0,5,0" Text="单包数据：" />
                        <TextBox Width="60"
                                 Text="{Binding MockPageSize, Mode=TwoWay}" />
                    </StackPanel>
                </HeaderedContentControl>
                <HeaderedContentControl Grid.Row="1" Header="Udp组播配置">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,5,0" Text="IP：" />
                        <TextBox Width="150" Text="{Binding UdpIp, Mode=TwoWay}" />

                        <TextBlock Margin="10,0,5,0" Text="端口：" />
                        <TextBox Width="60" Text="{Binding UdpPort, Mode=TwoWay}" />
                    </StackPanel>
                </HeaderedContentControl>
                <StackPanel
                    Grid.Row="2"
                    Margin="0,5"
                    Orientation="Horizontal">
                    <Button
                        Command="{Binding HandleRunCommandCommandAsync}"
                        Content="{codewf:If Condition={Binding IsRunning}, True=停止服务, False=开启服务}" />
                    <Button Command="{Binding RefreshCommand}" Content="刷新" />
                    <Button Command="{Binding UpdateCommand}" Content="更新" />
                </StackPanel>
                <HeaderedContentControl Header="日志" Grid.Row="3">
                    <codewf:LogView />
                </HeaderedContentControl>
                <StackPanel
                    Grid.Row="4"
                    Margin="0,8"
                    VerticalAlignment="Center">
                    <TextBlock Margin="0,5,0,5">
                        <Run Text="TCP服务：" />
                        <Run Text="    心跳时间：" />
                        <Run Foreground="Green" Text="{Binding HeartbeatTime, StringFormat=yyyy-MM-dd HH:mm:ss fff}" />
                        <Run Text="    客户端：" />
                        <Run Foreground="Green" Text="{Binding ClientCount, Mode=OneWay}" />

                    </TextBlock>
                    <TextBlock>
                        <Run Text="UDP组播：" />
                        <Run Foreground="Green" Text="2023-12-16 11:27" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </TabItem>
        <TabItem Header="文件传输">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <HeaderedContentControl Grid.Row="0" Header="选择客户端">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,5,0" Text="客户端：" />
                        <ComboBox Width="200" ItemsSource="{Binding ConnectedClients, Mode=OneWay}"
                                  SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                                  DisplayMemberBinding="{Binding Key, Mode=OneWay}" />
                    </StackPanel>
                </HeaderedContentControl>
                <HeaderedContentControl Grid.Row="1" Header="文件操作">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SelectFilesCommand}" Content="选择文件(批量)" Margin="5,0" />
                        <Button Command="{Binding UploadFilesCommand}" Content="上传文件" Margin="5,0" />
                        <Button Command="{Binding DownloadFilesCommand}" Content="下载文件" Margin="5,0" />
                        <Button Command="{Binding CancelTransferCommand}" Content="取消传输" Margin="5,0" />
                    </StackPanel>
                </HeaderedContentControl>
                <HeaderedContentControl Grid.Row="2" Header="传输列表">
                    <DataGrid CanUserReorderColumns="True" CanUserResizeColumns="True" CanUserSortColumns="True"
                              GridLinesVisibility="All" ScrollViewer.AllowAutoHide="False" FontSize="12"
                              HeadersVisibility="Column" IsReadOnly="True" BorderThickness="1" BorderBrush="#33000000"
                              ItemsSource="{Binding FileTransferList, Mode=OneWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="150" Binding="{Binding FileName, Mode=OneWay}" Header="文件名" />
                            <DataGridTextColumn Width="100" Binding="{Binding FileSize, Mode=OneWay, StringFormat={}{0} bytes}" Header="文件大小" />
                            <DataGridTextColumn Width="150" Binding="{Binding Progress, Mode=OneWay, StringFormat={}{0:F2}%}" Header="进度" />
                            <DataGridTextColumn Width="100" Binding="{Binding Status, Mode=OneWay}" Header="状态" />
                            <DataGridTextColumn Width="*" Binding="{Binding Message, Mode=OneWay}" Header="信息" />
                        </DataGrid.Columns>
                    </DataGrid>
                </HeaderedContentControl>
                <StackPanel Grid.Row="3" Margin="0,5" Orientation="Horizontal">
                    <TextBlock Margin="0,0,20,0">
                        <Run Text="总进度：" />
                        <Run Foreground="Green" Text="{Binding TotalProgress, StringFormat={}{0:F2}%}" />
                    </TextBlock>
                    <TextBlock>
                        <Run Text="传输速度：" />
                        <Run Foreground="Green" Text="{Binding TransferSpeed, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>