<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="using:Prism.Mvvm"
             xmlns:vm="using:SocketTest.Server.Shell.ViewModels"
             mc:Ignorable="d"
             x:Class="SocketTest.Server.Shell.Views.Controls.ServerStatusBarView"
             prism:ViewModelLocator.AutoWireViewModel="True"
             x:DataType="vm:ServerStatusBarViewModel">
    <Border Padding="14,10"
            Background="#111827"
            CornerRadius="8">
        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="8">
            <TextBlock Foreground="#9CA3AF" Text="状态" />
            <TextBlock Grid.Column="1" Foreground="White" TextTrimming="CharacterEllipsis"
                       Text="{Binding ServiceStatusText}" />
            <TextBlock Grid.Column="2" Foreground="#9CA3AF" Text="进程数" />
            <TextBlock Grid.Column="3" Foreground="White" Text="{Binding CurrentProcessCount}" />
            <TextBlock Grid.Column="4" Foreground="#9CA3AF" Text="客户端" />
            <TextBlock Grid.Column="5" Foreground="White" Text="{Binding ClientCount}" />
        </Grid>
    </Border>
</UserControl>
