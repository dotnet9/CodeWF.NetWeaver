<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SocketTest.Server.Shell.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:codewf="https://codewf.com"
        mc:Ignorable="d"
        d:DesignWidth="880"
        d:DesignHeight="640"
        Width="880"
        Height="640"
        MinWidth="760"
        MinHeight="520"
        x:Class="SocketTest.Server.Shell.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.ico"
        Title="SocketTest.Server">
    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="#D9E2EC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid Background="#F5F7FA" RowDefinitions="Auto,*,Auto">
        <Border Padding="20,16"
                Background="#FFFFFF"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="SocketTest.Server" />
                    <TextBlock Foreground="#667085"
                               Text="启动时自动生成并写回标准 .NET 配置文件，界面仅保留核心状态与运行日志。" />
                </StackPanel>
                <Button Grid.Column="1"
                        MinWidth="120"
                        Height="38"
                        HorizontalAlignment="Right"
                        Command="{Binding ToggleServerAsync}"
                        Content="{Binding StartButtonText}" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="panel" Margin="18" Padding="12">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Margin="4,0,0,10" FontSize="16" FontWeight="SemiBold" Text="运行日志" />
                <codewf:LogView Grid.Row="1" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="18,0,18,18"
                Padding="14,10"
                Background="#111827"
                CornerRadius="12">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*" ColumnSpacing="18">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Foreground="#9CA3AF" Text="状态" />
                    <TextBlock Foreground="White" Text="{Binding ServiceStatusText}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <TextBlock Foreground="#9CA3AF" Text="进程数" />
                    <TextBlock Foreground="White" Text="{Binding CurrentProcessCount}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                    <TextBlock Foreground="#9CA3AF" Text="客户端" />
                    <TextBlock Foreground="White" Text="{Binding ClientCount}" />
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                    <TextBlock Foreground="#9CA3AF" Text="心跳" />
                    <TextBlock Foreground="White" Text="{Binding HeartbeatTime, StringFormat=yyyy-MM-dd HH:mm:ss}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
