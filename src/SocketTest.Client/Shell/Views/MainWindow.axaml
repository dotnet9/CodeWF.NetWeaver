<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:SocketTest.Client.Shell.Views.Controls"
        xmlns:codewf="https://codewf.com"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1440"
        d:DesignHeight="960"
        Width="1440"
        Height="960"
        MinWidth="1180"
        MinHeight="760"
        x:Class="SocketTest.Client.Shell.Views.MainWindow"
        Icon="/Assets/logo.ico"
        Title="SocketTest.Client">
    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="#D8DEE9" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Styles>

    <Grid Background="#F5F7FA" RowDefinitions="Auto,*,220,Auto">
        <controls:ClientConnectionPanelView />

        <controls:ClientModuleTabsView Grid.Row="1"
                                       Margin="18,18,18,12" />

        <Border Grid.Row="2" Classes="panel" Margin="18,0,18,12" Padding="12">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Margin="4,0,0,10" FontSize="16" FontWeight="SemiBold" Text="运行日志" />
                <codewf:LogView Grid.Row="1" />
            </Grid>
        </Border>

        <controls:ClientStatusBarView Grid.Row="3"
                                      Margin="18,0,18,18" />
    </Grid>
</Window>
