<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SocketTest.Client.Shell.ViewModels"
             xmlns:controls="using:SocketTest.Client.Shell.Views.Controls"
             mc:Ignorable="d"
             x:Class="SocketTest.Client.Shell.Views.Controls.ClientStatusBarView"
             x:DataType="vm:ClientStatusBarViewModel">
    <Border Padding="14,10"
            Background="#111827"
            CornerRadius="12">
        <Grid>
            <ContentControl Content="{Binding ProcessMonitorStatusViewModel}"
                            IsVisible="{Binding IsProcessMonitorTabSelected}">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <controls:ProcessMonitorStatusView />
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
            <ContentControl Content="{Binding RemoteFileExplorerStatusViewModel}"
                            IsVisible="{Binding IsRemoteFileExplorerTabSelected}">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <controls:RemoteFileExplorerStatusView />
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
            <ContentControl Content="{Binding FileTransferStatusViewModel}"
                            IsVisible="{Binding IsFileTransferTabSelected}">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <controls:FileTransferStatusView />
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
        </Grid>
    </Border>
</UserControl>
