<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="using:Prism.Mvvm"
             xmlns:vm="using:SocketTest.Client.Shell.ViewModels"
             xmlns:controls="using:SocketTest.Client.Shell.Views.Controls"
             mc:Ignorable="d"
             x:Class="SocketTest.Client.Shell.Views.Controls.ClientStatusBarView"
             x:Name="Root"
             prism:ViewModelLocator.AutoWireViewModel="True"
             x:DataType="vm:ClientStatusBarViewModel">
    <Border Padding="14,10"
            Background="#111827"
            CornerRadius="12">
        <Grid>
            <controls:ProcessMonitorStatusView IsVisible="{Binding #Root.DataContext.IsProcessMonitorTabSelected}" />
            <controls:RemoteFileExplorerStatusView IsVisible="{Binding #Root.DataContext.IsRemoteFileExplorerTabSelected}" />
            <controls:FileTransferStatusView IsVisible="{Binding #Root.DataContext.IsFileTransferTabSelected}" />
        </Grid>
    </Border>
</UserControl>
