<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="using:Prism.Mvvm"
             xmlns:vm="using:SocketTest.Client.Shell.ViewModels"
             mc:Ignorable="d"
             x:Class="SocketTest.Client.Shell.Views.Controls.RemoteFileExplorerStatusView"
             prism:ViewModelLocator.AutoWireViewModel="True"
             x:DataType="vm:RemoteFileExplorerStatusViewModel">
    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="8">
        <TextBlock Foreground="#9CA3AF" Text="当前目录" />
        <TextBlock Grid.Column="1" Foreground="White" TextTrimming="CharacterEllipsis"
                   Text="{Binding CurrentDirectoryPath}" />
        <TextBlock Grid.Column="2" Foreground="#9CA3AF" Text="浏览概览" />
        <TextBlock Grid.Column="3" Foreground="White" TextTrimming="CharacterEllipsis" Text="{Binding ExplorerSummary}" />
        <TextBlock Grid.Column="4" Foreground="#9CA3AF" Text="当前状态" />
        <TextBlock Grid.Column="5" Foreground="White" TextTrimming="CharacterEllipsis" Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>
