<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SocketTest.Client.Shell.ViewModels"
             mc:Ignorable="d"
             x:Class="SocketTest.Client.Shell.Views.Controls.RemoteFileExplorerStatusView"
             x:DataType="vm:RemoteFileExplorerStatusViewModel">
    <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="18">
        <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Foreground="#9CA3AF" Text="当前目录" />
            <TextBlock Foreground="White" Text="{Binding CurrentDirectoryPath}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
            <TextBlock Foreground="#9CA3AF" Text="浏览概览" />
            <TextBlock Foreground="White" Text="{Binding ExplorerSummary}" />
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
            <TextBlock Foreground="#9CA3AF" Text="当前状态" />
            <TextBlock Foreground="White" Text="{Binding StatusMessage}" />
        </StackPanel>
    </Grid>
</UserControl>
