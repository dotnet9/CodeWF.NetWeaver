<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="using:Prism.Mvvm"
             xmlns:vm="using:SocketTest.Client.Shell.ViewModels"
             mc:Ignorable="d"
             x:Class="SocketTest.Client.Shell.Views.Controls.ClientConnectionPanelView"
             prism:ViewModelLocator.AutoWireViewModel="True"
             x:DataType="vm:ClientConnectionPanelViewModel">
    <Border Padding="18,14"
            Background="#FFFFFF"
            BorderBrush="#E5E7EB"
            BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="14">
            <StackPanel Spacing="4">
                <TextBlock FontSize="22" FontWeight="SemiBold" Text="SocketTest.Client" />
                <TextBlock Foreground="#667085"
                           Text="TCP/UDP 客户端示例" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock VerticalAlignment="Center" Text="服务端地址" />
                <TextBox Width="150"
                         Height="34"
                         Text="{Binding TcpIp, Mode=TwoWay}"
                         PlaceholderText="127.0.0.1" />

                <TextBlock VerticalAlignment="Center" Text="端口" />
                <TextBox Width="92"
                         Height="34"
                         Text="{Binding TcpPort, Mode=TwoWay}" />

                <Button MinWidth="116"
                        Height="34"
                        Command="{Binding HandleConnectTcpAsync}"
                        Content="{Binding ConnectButtonText}" />
            </StackPanel>

            <Border Grid.Column="2"
                    MinWidth="210"
                    Padding="12,7"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="8">
                <TextBlock Foreground="#475467"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding ConnectionSummary}" />
            </Border>
        </Grid>
    </Border>
</UserControl>
