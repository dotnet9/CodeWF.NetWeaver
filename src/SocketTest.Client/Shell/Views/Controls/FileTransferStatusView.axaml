<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SocketTest.Client.Shell.ViewModels"
             mc:Ignorable="d"
             x:Class="SocketTest.Client.Shell.Views.Controls.FileTransferStatusView"
             x:DataType="vm:FileTransferStatusViewModel">
    <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="18">
        <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Foreground="#9CA3AF" Text="队列概览" />
            <TextBlock Foreground="White" Text="{Binding FileTransferViewModel.QueueSummary}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
            <TextBlock Foreground="#9CA3AF" Text="实时速度" />
            <TextBlock Foreground="White" Text="{Binding FileTransferViewModel.TransferSpeed}" />
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
            <TextBlock Foreground="#9CA3AF" Text="总进度" />
            <TextBlock Foreground="White" Text="{Binding FileTransferViewModel.TotalProgress, StringFormat={}{0:F1}%}" />
        </StackPanel>
    </Grid>
</UserControl>
