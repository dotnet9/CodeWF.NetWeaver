<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="using:Prism.Mvvm"
             xmlns:vm="using:SocketTest.Client.Shell.ViewModels"
             mc:Ignorable="d"
             x:Class="SocketTest.Client.Shell.Views.Controls.FileTransferStatusView"
             prism:ViewModelLocator.AutoWireViewModel="True"
             x:DataType="vm:FileTransferStatusViewModel">
    <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="8">
        <TextBlock Foreground="#9CA3AF" Text="队列概览" />
        <TextBlock Grid.Column="1" Foreground="White" TextTrimming="CharacterEllipsis" Text="{Binding QueueSummary}" />
        <TextBlock Grid.Column="2" Foreground="#9CA3AF" Text="实时速度" />
        <TextBlock Grid.Column="3" Foreground="White" TextTrimming="CharacterEllipsis" Text="{Binding TransferSpeed}" />
        <TextBlock Grid.Column="4" Foreground="#9CA3AF" Text="总进度" />
        <TextBlock Grid.Column="5" Foreground="White" Text="{Binding TotalProgress, StringFormat={}{0:F1}%}" />
    </Grid>
</UserControl>
