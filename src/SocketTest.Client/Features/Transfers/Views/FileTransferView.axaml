<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="using:Prism.Mvvm"
             xmlns:vm="using:SocketTest.Client.Features.Transfers.ViewModels"
             xmlns:models="using:SocketTest.Client.Features.Transfers.Models"
             mc:Ignorable="d"
             d:DesignWidth="1280"
             d:DesignHeight="760"
             x:Class="SocketTest.Client.Features.Transfers.Views.FileTransferView"
             prism:ViewModelLocator.AutoWireViewModel="True"
             x:DataType="vm:FileTransferViewModel">
    <UserControl.Styles>
        <Style Selector="Border.surface">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="10" RowDefinitions="Auto,Auto,*">
        <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,12">
            <Border Classes="surface" Padding="16" Margin="0,0,8,0">
                <StackPanel Spacing="4">
                    <TextBlock Foreground="#667085" Text="总进度" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding TotalProgress, StringFormat={}{0:F1}%}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="surface" Padding="16" Margin="4,0">
                <StackPanel Spacing="4">
                    <TextBlock Foreground="#667085" Text="实时速度" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding TransferSpeed}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="surface" Padding="16" Margin="8,0,0,0">
                <StackPanel Spacing="4">
                    <TextBlock Foreground="#667085" Text="队列概览" />
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding QueueSummary}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Classes="surface" Padding="16" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*">
                <Button Command="{Binding PauseSelectedTransfers}" Content="批量停止" />
                <Button Grid.Column="1" Margin="8,0,0,0" Command="{Binding ResumeSelectedTransfers}" Content="批量继续" />
                <Button Grid.Column="2" Margin="8,0,0,0" Command="{Binding RemoveSelectedTransfers}" Content="删除选中" />
                <Button Grid.Column="3" Margin="8,0,0,0" Command="{Binding ClearCompletedTransfers}" Content="清理完成/失败" />
                <TextBlock Grid.Column="4"
                           HorizontalAlignment="Right"
                           Foreground="#667085"
                           Text="{Binding SelectedCount, StringFormat=已选中 {0} 项}" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Classes="surface" Padding="10">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Margin="4,0,0,10" FontSize="16" FontWeight="SemiBold" Text="传输记录" />
                <DataGrid Grid.Row="1"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          BorderThickness="0"
                          ItemsSource="{Binding FileTransferList}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="54" Header="选中">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:FileTransferItem">
                                    <CheckBox HorizontalAlignment="Center" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Width="160" Binding="{Binding DisplayName}" Header="名称" />
                        <DataGridTextColumn Width="90" Binding="{Binding DirectionText}" Header="方向" />
                        <DataGridTextColumn Width="270" Binding="{Binding SourcePath}" Header="来源" />
                        <DataGridTextColumn Width="270" Binding="{Binding DestinationPath}" Header="目标" />
                        <DataGridTextColumn Width="110" Binding="{Binding StateText}" Header="状态" />
                        <DataGridTemplateColumn Width="180" Header="进度">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:FileTransferItem">
                                    <StackPanel Spacing="6">
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" Height="8" />
                                        <TextBlock Text="{Binding ProgressText}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Width="150" Binding="{Binding TransferredText}" Header="已传输" />
                        <DataGridTextColumn Width="220" Binding="{Binding Detail}" Header="说明" />
                        <DataGridTemplateColumn Width="170" Header="操作">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:FileTransferItem">
                                    <Border Padding="0">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="停止 / 继续" Click="ToggleTransferMenuItem_OnClick" />
                                                <MenuItem Header="删除记录" Click="DeleteTransferMenuItem_OnClick" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button IsVisible="{Binding HasPrimaryAction}"
                                                    Content="{Binding ActionText}"
                                                    Command="{Binding $parent[DataGrid].((vm:FileTransferViewModel)DataContext).ToggleTransferState}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="删除"
                                                    Command="{Binding $parent[DataGrid].((vm:FileTransferViewModel)DataContext).RemoveTransfer}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
