<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SocketTest.Client.ViewModels"
             xmlns:models="using:SocketTest.Client.Models"
             mc:Ignorable="d"
             d:DesignWidth="1280"
             d:DesignHeight="760"
             x:Class="SocketTest.Client.Views.RemoteFileManagerView"
             x:DataType="vm:RemoteFileManagerViewModel">
    <UserControl.Styles>
        <Style Selector="Border.surface">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.tile-card">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Width" Value="208" />
            <Setter Property="Height" Value="148" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Classes="surface" Padding="16" Margin="0,0,0,12">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
                <TextBlock Text="当前目录" Margin="0,0,10,0" />
                <TextBox Grid.Column="1"
                         Text="{Binding CurrentServerDirectory, Mode=TwoWay}"
                         Watermark="输入服务端目录后点击进入"
                         Margin="0,0,10,0" />
                <Button Grid.Column="2" Command="{Binding GoToDirectoryCommand}" Content="进入" />
                <Button Grid.Column="3" Margin="8,0,0,0" Command="{Binding EnterParentDirectoryCommand}" Content="上一级" />
                <Button Grid.Column="4" Margin="8,0,0,0" Command="{Binding RefreshServerDirectoryCommand}" Content="刷新" />
                <Button Grid.Column="5" Margin="20,0,0,0" Command="{Binding SwitchToListViewCommand}" Content="列表" />
                <Button Grid.Column="6" Margin="8,0,0,0" Command="{Binding SwitchToTileViewCommand}" Content="方块" />
                <Button Grid.Column="7" Margin="20,0,0,0" Click="CreateDirectoryButton_OnClick" Content="创建目录" />
                <Button Grid.Column="8" Margin="8,0,0,0" Click="DeleteButton_OnClick" Content="删除选中" />

                <TextBlock Grid.Row="1" Margin="0,12,10,0" Text="搜索" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,12,10,0"
                         Text="{Binding SearchKeyword, Mode=TwoWay}"
                         Watermark="支持当前目录搜索，可递归子目录与子文件" />
                <CheckBox Grid.Row="1"
                          Grid.Column="2"
                          Margin="0,12,0,0"
                          IsChecked="{Binding SearchRecursive, Mode=TwoWay}"
                          Content="递归搜索" />
                <Button Grid.Row="1" Grid.Column="3" Margin="8,12,0,0" Command="{Binding StartSearchCommand}" Content="搜索" />
                <Button Grid.Row="1" Grid.Column="4" Margin="8,12,0,0" Command="{Binding ClearSearchCommand}" Content="清除搜索" />
                <Button Grid.Row="1" Grid.Column="7" Margin="0,12,0,0" Click="UploadFilesButton_OnClick" Content="上传文件" />
                <Button Grid.Row="1" Grid.Column="8" Margin="8,12,0,0" Click="UploadFolderButton_OnClick" Content="上传文件夹" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,12">
            <Border Classes="surface" Padding="16" Margin="0,0,8,0">
                <TextBlock Text="{Binding StatusText}" />
            </Border>
            <Button Grid.Column="1" Margin="0,0,8,0" Click="DownloadSelectionButton_OnClick" Content="下载选中" />
            <Button Grid.Column="2" Click="UploadFilesButton_OnClick" Content="上传到当前目录" />
        </Grid>

        <Border Grid.Row="3" Classes="surface" Padding="10">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="创建目录" Click="CreateDirectoryButton_OnClick" />
                    <MenuItem Header="上传文件" Click="UploadFilesButton_OnClick" />
                    <MenuItem Header="上传文件夹" Click="UploadFolderButton_OnClick" />
                    <MenuItem Header="刷新当前目录" Command="{Binding RefreshServerDirectoryCommand}" />
                </ContextMenu>
            </Border.ContextMenu>

            <Grid RowDefinitions="Auto,*">
                <Grid ColumnDefinitions="*,Auto" Margin="4,0,4,10">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding SearchSummary}" />
                    <TextBlock Grid.Column="1" Foreground="#667085" Text="{Binding CurrentServerDirectory}" />
                </Grid>

                <Grid Grid.Row="1">
                    <DataGrid IsVisible="{Binding IsListView}"
                              CanUserReorderColumns="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              BorderThickness="0"
                              ItemsSource="{Binding VisibleItems}"
                              SelectedItem="{Binding SelectedServerItem, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="90" Binding="{Binding EntryTypeText}" Header="类型" />
                            <DataGridTemplateColumn Width="240" Header="名称">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="models:ServerDirectoryItem">
                                        <Button HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Command="{Binding $parent[UserControl].((vm:RemoteFileManagerViewModel)DataContext).OpenItemCommand}"
                                                CommandParameter="{Binding}">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="打开" Click="OpenItemMenuItem_OnClick" />
                                                    <MenuItem Header="创建目录" Click="CreateDirectoryForItemMenuItem_OnClick" />
                                                    <MenuItem Header="删除" Click="DeleteItemMenuItem_OnClick" />
                                                    <Separator />
                                                    <MenuItem Header="上传文件到此处" Click="UploadFilesForItemMenuItem_OnClick" />
                                                    <MenuItem Header="上传文件夹到此处" Click="UploadFolderForItemMenuItem_OnClick" />
                                                    <MenuItem Header="下载此项" Click="DownloadItemMenuItem_OnClick" />
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Border Width="36"
                                                        Height="36"
                                                        CornerRadius="10"
                                                        Background="#F2F4F7">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontWeight="Bold"
                                                               Text="{Binding IconText}" />
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                    <TextBlock Foreground="#667085" Text="{Binding FullPath}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Width="140" Binding="{Binding SizeText}" Header="大小" />
                            <DataGridTextColumn Width="170" Binding="{Binding LastModifiedText}" Header="修改时间" />
                            <DataGridTextColumn Width="360" Binding="{Binding FullPath}" Header="完整路径" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <ScrollViewer IsVisible="{Binding IsTileView}" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding VisibleItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ServerDirectoryItem">
                                    <Border Classes="tile-card">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="打开" Click="OpenItemMenuItem_OnClick" />
                                                <MenuItem Header="创建目录" Click="CreateDirectoryForItemMenuItem_OnClick" />
                                                <MenuItem Header="删除" Click="DeleteItemMenuItem_OnClick" />
                                                <Separator />
                                                <MenuItem Header="上传文件到此处" Click="UploadFilesForItemMenuItem_OnClick" />
                                                <MenuItem Header="上传文件夹到此处" Click="UploadFolderForItemMenuItem_OnClick" />
                                                <MenuItem Header="下载此项" Click="DownloadItemMenuItem_OnClick" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                Command="{Binding $parent[UserControl].((vm:RemoteFileManagerViewModel)DataContext).OpenItemCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Spacing="10">
                                                <Border Width="52" Height="52" CornerRadius="14" Background="#F2F4F7">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Text="{Binding IconText}" />
                                                </Border>
                                                <TextBlock FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="40"
                                                           Text="{Binding Name}" />
                                                <TextBlock Foreground="#667085" Text="{Binding EntryTypeText}" />
                                                <TextBlock Foreground="#667085" Text="{Binding SizeText}" />
                                            </StackPanel>
                                        </Button>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="4" IsVisible="{Binding IsSearchMode}" Padding="12,10" Background="#101828" CornerRadius="12" Margin="0,12,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Foreground="White" Text="{Binding SearchSummary}" />
                <Button Grid.Column="1"
                        Margin="10,0,0,0"
                        Command="{Binding PreviousSearchPageCommand}"
                        IsEnabled="{Binding CanGoPreviousSearchPage}"
                        Content="上一页" />
                <Button Grid.Column="2"
                        Margin="8,0,0,0"
                        Command="{Binding NextSearchPageCommand}"
                        IsEnabled="{Binding CanGoNextSearchPage}"
                        Content="下一页" />
                <TextBlock Grid.Column="3" Margin="12,0,0,0" Foreground="#D0D5DD" Text="{Binding CurrentServerDirectory}" />
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsCreateDialogOpen}" Background="#66000000" ZIndex="20">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="420" Classes="surface" Padding="20">
                    <StackPanel Spacing="14">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="创建目录" />
                        <TextBlock Foreground="#667085" Text="{Binding CreateDialogHint}" />
                        <TextBox Text="{Binding PendingDirectoryName, Mode=TwoWay}" Watermark="请输入目录名称" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Command="{Binding ConfirmCreateDirectoryCommand}" Content="确认创建" />
                            <Button Grid.Column="1" Command="{Binding CancelCreateDirectoryCommand}" Content="取消" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsDeleteDialogOpen}" Background="#66000000" ZIndex="20">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="420" Classes="surface" Padding="20">
                    <StackPanel Spacing="14">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="确认删除" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding DeleteDialogMessage}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Command="{Binding ConfirmDeleteCommand}" Content="确认删除" />
                            <Button Grid.Column="1" Command="{Binding CancelDeleteCommand}" Content="取消" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
