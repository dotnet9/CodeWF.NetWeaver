<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SocketTest.Client.ViewModels"
        xmlns:views="using:SocketTest.Client.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="850"
        Width="1000" Height="850"
        x:Class="SocketTest.Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.ico"
        Title="SocketTest.Client">

    <TabControl>
        <TabItem Header="进程监控">
            <views:ProcessMonitorView DataContext="{Binding ProcessMonitorViewModel}" />
        </TabItem>
        <TabItem Header="远程文件管理">
            <views:RemoteFileManagerView DataContext="{Binding RemoteFileManagerViewModel}" />
        </TabItem>
        <TabItem Header="文件传输">
            <views:FileTransferView DataContext="{Binding FileTransferViewModel}" />
        </TabItem>
    </TabControl>
</Window>