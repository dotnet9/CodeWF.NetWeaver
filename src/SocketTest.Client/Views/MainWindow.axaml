<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SocketTest.Client.ViewModels"
        xmlns:views="using:SocketTest.Client.Views"
        xmlns:codewf="https://codewf.com"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1440"
        d:DesignHeight="960"
        Width="1440"
        Height="960"
        MinWidth="1180"
        MinHeight="760"
        x:Class="SocketTest.Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.ico"
        Title="SocketTest.Client">
    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="#D8DEE9" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Styles>

    <Grid Background="#F5F7FA" RowDefinitions="Auto,*,220,Auto">
        <Border Padding="20,16"
                Background="#FFFFFF"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,140,Auto,110,Auto,Auto" ColumnSpacing="10">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="22" FontWeight="SemiBold" Text="SocketTest.Client" />
                    <TextBlock Foreground="#667085" Text="统一连接、统一日志、统一状态栏，让进程监控、远程文件管理和文件传输协同更清晰。" />
                </StackPanel>

                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="服务端地址" />
                <TextBox Grid.Column="2"
                         Height="36"
                         Text="{Binding ProcessMonitorViewModel.TcpIp, Mode=TwoWay}"
                         Watermark="127.0.0.1" />

                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="端口" />
                <TextBox Grid.Column="4"
                         Height="36"
                         Text="{Binding ProcessMonitorViewModel.TcpPort, Mode=TwoWay}" />

                <Button Grid.Column="5"
                        MinWidth="120"
                        Height="36"
                        Command="{Binding ProcessMonitorViewModel.HandleConnectTcpAsync}"
                        Content="{Binding ProcessMonitorViewModel.ConnectButtonText}" />

                <Border Grid.Column="6"
                        Padding="12,8"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="10">
                    <TextBlock Foreground="#475467"
                               Text="{Binding ProcessMonitorViewModel.ConnectionSummary}" />
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="18,18,18,12"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="进程监控">
                <views:ProcessMonitorView DataContext="{Binding ProcessMonitorViewModel}" />
            </TabItem>
            <TabItem Header="远程文件管理">
                <views:RemoteFileManagerView DataContext="{Binding RemoteFileManagerViewModel}" />
            </TabItem>
            <TabItem Header="文件传输">
                <views:FileTransferView DataContext="{Binding FileTransferViewModel}" />
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Classes="panel" Margin="18,0,18,12" Padding="12">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Margin="4,0,0,10" FontSize="16" FontWeight="SemiBold" Text="运行日志" />
                <codewf:LogView Grid.Row="1" />
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="18,0,18,18"
                Padding="14,10"
                Background="#111827"
                CornerRadius="12">
            <Grid>
                <Grid IsVisible="{Binding IsProcessMonitorTabSelected}"
                      ColumnDefinitions="Auto,Auto,Auto,*"
                      ColumnSpacing="18">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Foreground="#9CA3AF" Text="TCP" />
                        <TextBlock Foreground="White" Text="{Binding ProcessMonitorViewModel.ConnectionSummary}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <TextBlock Foreground="#9CA3AF" Text="UDP" />
                        <TextBlock Foreground="White" Text="{Binding ProcessMonitorViewModel.UdpSummary}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                        <TextBlock Foreground="#9CA3AF" Text="进程概览" />
                        <TextBlock Foreground="White" Text="{Binding ProcessMonitorViewModel.ProcessSummary}" />
                    </StackPanel>
                </Grid>

                <Grid IsVisible="{Binding IsRemoteFileManagerTabSelected}"
                      ColumnDefinitions="Auto,Auto,Auto,*"
                      ColumnSpacing="18">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Foreground="#9CA3AF" Text="当前目录" />
                        <TextBlock Foreground="White" Text="{Binding RemoteFileManagerViewModel.CurrentServerDirectory}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <TextBlock Foreground="#9CA3AF" Text="浏览概览" />
                        <TextBlock Foreground="White" Text="{Binding RemoteFileManagerViewModel.SearchSummary}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                        <TextBlock Foreground="#9CA3AF" Text="当前状态" />
                        <TextBlock Foreground="White" Text="{Binding RemoteFileManagerViewModel.StatusText}" />
                    </StackPanel>
                </Grid>

                <Grid IsVisible="{Binding IsFileTransferTabSelected}"
                      ColumnDefinitions="Auto,Auto,Auto,*"
                      ColumnSpacing="18">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Foreground="#9CA3AF" Text="队列概览" />
                        <TextBlock Foreground="White" Text="{Binding FileTransferViewModel.QueueSummary}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <TextBlock Foreground="#9CA3AF" Text="实时速度" />
                        <TextBlock Foreground="White" Text="{Binding FileTransferViewModel.TransferSpeed}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                        <TextBlock Foreground="#9CA3AF" Text="总进度" />
                        <TextBlock Foreground="White" Text="{Binding FileTransferViewModel.TotalProgress, StringFormat={}{0:F1}%}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
